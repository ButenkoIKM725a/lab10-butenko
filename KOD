#include <iostream>
#include <string>
#include <vector>
using namespace std;
struct Student {
    string surname;
    string faculty;
    string group;
    int absences;
};
void print_student(const Student& s) {
    cout << "Surname: " << s.surname
        << " | Faculty: " << s.faculty
        << " | Group: " << s.group
        << " | Absences: " << s.absences << endl;
}
int main() {
    int n;
    cout << "Enter the number of students: ";
    cin >> n;
    Student* students = new Student[n];
    for (int i = 0; i < n; i++) {
        cout << "\nStudent" << i + 1 << ":" << endl;
        cout << "Surname: "; cin >> students[i].surname;
        cout << "Faculty: "; cin >> students[i].faculty;
        cout << "Group: "; cin >> students[i].group;
        cout << "Absences: "; cin >> students[i].absences;
    }
    cout << "\n--- Complete list of students ---" << endl;
    for (int i = 0; i < n; i++) {
        print_student(students[i]);
    }
    int max_index = 0;
    for (int i = 1; i < n; i++) {
        if (students[i].absences > students[max_index].absences) {
            max_index = i;
        }
    }
    cout << "\n--- Student with the most absences ---" << endl;
    print_student(students[max_index]);
    delete[] students;
    return 0;
}
